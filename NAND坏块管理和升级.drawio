  <diagram name="第 1 页" id="FhAuJ61DrwCMc4Ao1SrH">
    <mxGraphModel dx="1306" dy="677" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="Wtbu22s13VtOahG4Z0uz-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;BOOTROM&amp;nbsp;&lt;/div&gt;&lt;div&gt;（根据头部信息决定是从spl0还是spl1启动, 如果spl有坏的，就从好的spl 启动）&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="60" y="80" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;SPL 0&lt;/div&gt;&lt;div&gt;(默认DDR FW 永远不会变 )&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="60" y="200" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;DDR FW 0&lt;/div&gt;&lt;div&gt;（小于256KB，放到一个block）&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="100" x="440" y="290" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;DDR FW 1&lt;br&gt;（小于256KB，放到一个block）&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="90" x="540" y="290" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;DDR 参数&lt;br&gt;（不做坏块管理，如果读数据有问题，重新training，然后重新保存）&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="130" x="630" y="290" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;SPL 1&lt;/div&gt;&lt;div&gt;(默认DDR FW 永远不会变 )&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="220" y="200" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;preboot.itb 0&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="60" y="340" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;preboot.itb 1&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="220" y="340" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=13;" value="spl OTA 同步升级方案：&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. CRC校验 检查spl0 / spl1是否都是OK的，如果都是OK的，检查当前使用的是哪个spl (通过读nand header 可以知道)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. 如果spl0/spl1 都没问题，说明更新一个分区不会变砖，此时更新没有使用的分区的 spl。如果有spl 损坏，那就更新损坏的spl，更新的时候跳过坏块。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. 更新后修改&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;nand header， 确保下次从新的spl启动。&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="330" x="50" y="480" as="geometry" />
        </mxCell>
        <mxCell id="Wtbu22s13VtOahG4Z0uz-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=13;" value="preboot.itb OTA 同步升级方案：&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;spl 0和preboot.itb 0 做绑定，spl 1和preboot.itb 1 做绑定&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. CRC校验 检查&lt;span style=&quot;text-align: center;&quot;&gt;preboot.itb &lt;/span&gt;0 /&amp;nbsp;&lt;span style=&quot;text-align: center;&quot;&gt;preboot.itb 1&lt;/span&gt;是否都是OK的，如果都是OK的，检查当前使用的是哪个&lt;span style=&quot;text-align: center;&quot;&gt;preboot.itb&lt;/span&gt;（通过读nand header 可以知道）。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. 如果&lt;span style=&quot;text-align: center;&quot;&gt;preboot.itb &lt;/span&gt;0 / &lt;span style=&quot;text-align: center;&quot;&gt;preboot.itb 1&lt;/span&gt;&amp;nbsp;都没问题，说明更新一个分区不会变砖，此时spl 更新0，那么preboot.itb 就更新0。如果有损坏的 preboot.itb，那么就尝试先修复坏的preboot.itb （好的拷贝过去），然后跟随 spl更新。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="330" x="420" y="480" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
